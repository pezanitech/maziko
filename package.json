{
    "name": "maziko",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently --kill-others-on-fail --prefix-colors 'green.bold,blue.bold' --prefix '[{name}]' --names 'Frontend,Backend' 'vite' 'go run main.go dev'",
        "build": "vite build && vite build --ssr && go build -o ./build/main",
        "start": "concurrently --kill-others-on-fail --prefix-colors 'green.bold,blue.bold' --prefix '[{name}]' --names 'SSR,App' 'node ssrBuild/assets/app.js' './build/main'",
        "clean": "rm -rfv .tmp build ssrBuild node_modules/{.vite,.vite-temp}",
        "clean:all": "pnpm clean && rm -rfv node_modules .pnpm-store && go clean -cache -testcache",
        "reset": "pnpm clean:all && pnpm install"
    },
    "dependencies": {
        "@inertiajs/react": "^2.0.8",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.4",
        "@tailwindcss/vite": "^4.1.4",
        "@types/node": "^22.15.2",
        "@types/react": "^19.1.2",
        "@vitejs/plugin-react": "^4.4.1",
        "autoprefixer": "^10.4.21",
        "axios": "^1.9.0",
        "concurrently": "^9.1.2",
        "laravel-vite-plugin": "^1.2.0",
        "postcss": "^8.5.3",
        "tailwindcss": "^4.1.4",
        "vite": "^6.3.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild"
        ]
    }
}
